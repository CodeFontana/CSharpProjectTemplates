@page "/not-found"
@layout MainLayout

<PageTitle>Not Found</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudText Align="Align.Center" Typo="Typo.h3">Sorry, there's nothing at this address.</MudText>
    <MudDivider DividerType="DividerType.Middle" Class="my-5" />
    <MudStack AlignItems="AlignItems.Center" Class="mt-6">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">Go Home</MudButton>
    </MudStack>
</MudContainer>
