@page "/"

<PageTitle>Blazor Server - Home</PageTitle>

<MudStack Spacing="6">

    <MudPaper Elevation="0" Class="app-hero home-hero pa-8">

        <MudStack Spacing="3" Class="home-hero-content">

            <MudText Typo="Typo.h2" Class="home-hero-headline">
                Build production Blazor apps,
                <span class="home-hero-accent">faster.</span>
            </MudText>

            <MudText Typo="Typo.body1" Class="home-hero-lead">
                A clean, opinionated starting point for Blazor Server with MudBlazor,
                a refined dark/light theme, structured navigation, and sensible defaults
                so you can focus on shipping features.
            </MudText>

            <MudStack Row="true" Spacing="2" Class="mt-2">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           Href="/counter"
                           EndIcon="@Icons.Material.Rounded.ArrowForward">
                    Try the demo
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           Size="Size.Large"
                           Href="https://mudblazor.com/"
                           Target="_blank"
                           StartIcon="@Icons.Material.Rounded.MenuBook">
                    Documentation
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    <MudGrid Spacing="4">
        <MudItem xs="12" sm="6" md="4" Class="d-flex">
            <MudPaper Elevation="0" Class="app-card pa-5">
                <MudStack Spacing="2" Class="flex-grow-1">
                    <MudAvatar Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Medium">
                        <MudIcon Icon="@Icons.Material.Rounded.Palette" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6">Refined theme</MudText>
                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                        A curated indigo + slate palette with carefully tuned contrast for both light and dark modes.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4" Class="d-flex">
            <MudPaper Elevation="0" Class="app-card pa-5">
                <MudStack Spacing="2" Class="flex-grow-1">
                    <MudAvatar Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Medium">
                        <MudIcon Icon="@Icons.Material.Rounded.SpaceDashboard" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6">Polished layout</MudText>
                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                        Flat top bar, sectioned sidebar, and proper typography rhythm built on Inter.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4" Class="d-flex">
            <MudPaper Elevation="0" Class="app-card pa-5">
                <MudStack Spacing="2" Class="flex-grow-1">
                    <MudAvatar Color="Color.Tertiary" Variant="Variant.Outlined" Size="Size.Medium">
                        <MudIcon Icon="@Icons.Material.Rounded.Speed" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6">Production ready</MudText>
                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                        Serilog, response compression, reconnect modal, and a feature-folder structure out of the box.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

</MudStack>
