@page "/counter"

<PageTitle>Blazor Server - Counter</PageTitle>

<MudStack Spacing="4" Class="counter-page">

    <MudStack Spacing="1">
        <MudText Typo="Typo.overline" Color="Color.Primary">Demo</MudText>
        <MudText Typo="Typo.h3" Class="counter-heading">Counter</MudText>
        <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">
            A tiny example of state, snackbars and inline alerts working together.
        </MudText>
    </MudStack>

    <MudPaper Elevation="0" Class="app-card counter-card pa-6">

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="6">
            <MudStack Spacing="0">
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                    CURRENT COUNT
                </MudText>
                <MudText Typo="Typo.h2" Class="counter-value">
                    @_currentCount
                </MudText>
            </MudStack>

            <MudSpacer />

            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Medium"
                           StartIcon="@Icons.Material.Rounded.Add"
                           OnClick="IncrementCount">
                    Increment
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           Size="Size.Medium"
                           StartIcon="@Icons.Material.Rounded.Refresh"
                           OnClick="ResetCount">
                    Reset
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    <Notification @ref="_notification" />

</MudStack>

@code {
    private int _currentCount = 0;
    private Notification _notification = default!;

    private void IncrementCount()
    {
        _notification.ResetAlert();
        _currentCount += 1;

        if (_currentCount % 6 == 0) { _notification.AlertError($"The current count is {_currentCount}"); }
        else if (_currentCount % 5 == 0) { _notification.FireError($"The current count is: {_currentCount}"); }
        else if (_currentCount % 4 == 0) { _notification.FireWarning($"The current count is: {_currentCount}"); }
        else if (_currentCount % 3 == 0) { _notification.FireInfo($"The current count is: {_currentCount}"); }
        else if (_currentCount % 2 == 0) { _notification.FireSuccess($"The current count is: {_currentCount}"); }
        else if (_currentCount % 1 == 0) { _notification.FireNormal($"The current count is: {_currentCount}"); }
    }

    private void ResetCount()
    {
        _currentCount = 0;
        _notification.ResetAlert();
    }
}
